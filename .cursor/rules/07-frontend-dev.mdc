## Type Definitions (mirror the FastAPI models exactly)

```typescript
// src/types/api.ts
export interface GenerateRequest { topic: string }
export interface GenerateResponse { session_id: string }

export interface StatusResponse {
  status: "running" | "awaiting_tutor" | "completed" | "rejected" | "error"
  current_node: string
  tutor_question?: string
  progress_pct: number
}

export interface TutorRespondRequest {
  approved: boolean
  feedback?: string
  error_clarification?: string
}

export interface ResultResponse {
  student_path: string
  tutor_path: string
  student_score: number
  tutor_score: number
  passed: boolean
  summary: string
}

export class ApiError extends Error {
  constructor(public status: number, public detail: string) {
    super(detail)
  }
}
```

## Polling with React Query (no hand-rolled setInterval)

```typescript
// src/hooks/useGenerationFlow.ts
import { useQuery, useMutation } from "@tanstack/react-query"

export function useGenerationFlow(sessionId: string | null) {
  const status = useQuery({
    queryKey: ["status", sessionId],
    queryFn: () => api.getStatus(sessionId!),
    enabled: !!sessionId,
    refetchInterval: (data) =>
      data?.status === "completed" || data?.status === "rejected" ? false : 2000,
    retry: 3,
  })
  return { status }
}
```

## UI Flow with All Error States Handled

```
[GenerateForm]
  → topic empty: inline validation error
  → topic > 500 chars: inline validation error
  → submit: POST /generate
      → network error: ErrorBanner "Could not connect to server"
      → 422: ErrorBanner "Please enter a valid topic (3–500 characters)"
      → 200: navigate to /session/:id

[PipelineStepper] — polls /status every 2s
  → 8 nodes shown as steps (completed ✅ / active 🔄 / pending ⬜)
  → aria-live="polite" so screen readers announce progress
  → status = "awaiting_tutor": show TutorPanel
  → status = "rejected": show RejectedState ("The tutor rejected this plan")
  → status = "error": ErrorBanner + retry option

[TutorPanel]
  → Approve button: POST /tutor/respond { approved: true }
  → Reject button: expands feedback textarea → POST { approved: false, feedback }
  → Loading state on submit — disable buttons while in-flight
  → 409 (already responded): "Plan already reviewed"

[ResultPanel]
  → Score badge: green (pass ≥ 80) / red (fail)
  → react-markdown renders student_notes preview
  → Download buttons: GET note files → trigger browser download
  → Retry option if score < 80 and retries available
```

## Accessibility Checklist (non-negotiable)

- [ ] All buttons have descriptive `aria-label` or visible text
- [ ] Pipeline stepper uses `role="list"` and `role="listitem"`
- [ ] Status updates use `aria-live="polite"` — no silent DOM changes
- [ ] Colour alone never conveys status — always paired with icon or text
- [ ] Tab order is logical — no `tabIndex > 0`
- [ ] Form inputs have associated `<label>` elements

## Performance Checklist

- [ ] `react-markdown` is lazy-loaded — only imported when result is shown
- [ ] Polling stops immediately on `completed` or `rejected` — no wasted requests
- [ ] Vite build produces ≤ 200KB gzipped bundle
- [ ] Images (if any) are WebP with `width`/`height` set to prevent CLS

