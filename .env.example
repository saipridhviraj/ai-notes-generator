GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
APP_API_KEY=your_app_api_key_here

# LLM provider: groq (default) or ollama
# USE_OLLAMA=true
# LLM_PROVIDER=ollama

# Prompt profile: dev (trimmed, Groq free tier) or production (full quality)
# Auto: production when USE_OLLAMA=true, dev when Groq
# USE_PRODUCTION_PROMPTS=true
# PROMPT_PROFILE=production

# Ollama (when USE_OLLAMA=true or LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b-q4_K_M
# Qwen 3.x: keep thinking off (OLLAMA_THINK=false). Model is current through 2026 — direct output is enough.
OLLAMA_THINK=false
# Style reference cap for 9B + 8K context (set to full to load entire Day-1 example)
# FEW_SHOT_MAX_CHARS=4500
OLLAMA_NUM_CTX=8192
OLLAMA_KEEP_ALIVE=30m
OLLAMA_TIMEOUT=600

# Ollama speed profile (simple topics ~3–5 min target)
# OLLAMA_FAST_MODE=true
# OLLAMA_2MIN_MODE=true
# OLLAMA_TARGET_MINUTES=2
# OLLAMA_NOTE_MAX_TOKENS=2048
# OLLAMA_NUM_CTX=4096
# TUTOR_SUPPLEMENT_MODE=true
# TUTOR_SUPPLEMENT_MAX_TOKENS=768
# FEW_SHOT_MAX_CHARS=2000
# RESEARCH_MAX_TOKENS=512
# EVAL_MODE=light          # heuristic | light (default on Ollama) | full
# FAST_EVAL_HEURISTIC=true # force Python-only eval (~1s, no LLM)
# EVAL_MAX_TOKENS=384      # light eval JSON cap (full mode default 2048)
# MAX_EVAL_RETRIES=2       # gap-bridger repair cycles before save (default 2)
# MERMAID_MAX_RETRIES=2    # mermaid repair passes in student notes (default 2)

APP_HOST=0.0.0.0
APP_PORT=8000
MAX_EVAL_RETRIES=2
# Diagram rendering: false = inline Mermaid in notes (default), true = JSON/SVG pipeline
DIAGRAM_PIPELINE=false
# How supplement/repair diagrams are generated: json (LLM JSON → Python Mermaid) or mermaid
MERMAID_GENERATION_MODE=json
MIN_MERMAID_DIAGRAMS=2
MERMAID_MAX_RETRIES=2

# Pipeline speed / token caps (optional)
# RESEARCH_MAX_TOKENS=1024
# GAP_MAX_TOKENS=1024
# FINAL_SUMMARY_LLM=false
# MIN_NOTE_CHARS=500

# Persistence
CHECKPOINT_DB_PATH=data/checkpoints.db
SESSION_DB_PATH=data/sessions.db
COURSE_DB_PATH=data/courses.db

# CORS (comma-separated origins for frontend)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# When Ollama is down, fall back to Groq if GROQ_API_KEY is set
LLM_FALLBACK_GROQ=true

# Stream LLM tokens to frontend via GET /stream/{session_id} (SSE)
LLM_STREAMING=true

# VB Academy integration — note.ready webhook + outbox retry
# NOTE_READY_ENABLED=true
# NOTE_READY_WEBHOOK_URL=http://localhost:9000/internal/events/note-ready
# NOTE_READY_WEBHOOK_SECRET=shared-hmac-secret
# NOTE_READY_OUTBOX_DB_PATH=data/note_events.db
# NOTE_READY_RETRY_INTERVAL_SEC=300
# NOTE_READY_RETRY_BACKOFF_SEC=30
# NOTE_READY_MAX_ATTEMPTS=20
# NOTE_READY_WEBHOOK_TIMEOUT_SEC=10

# Rate limits (slowapi)
RATE_LIMIT_GENERATE=5/minute
RATE_LIMIT_TUTOR=10/minute
